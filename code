#include <BLEDevice.h>
#include <BLEServer.h>
#include <BLEUtils.h>
#include <BLE2902.h>

#define LD2450_RX 16
#define LD2450_TX 17

HardwareSerial ld2450(2);

// ===== BLE SETTINGS =====
#define BLE_NAME "ESP32_LD2450"

#define SERVICE_UUID        "12345678"
#define CHARACTERISTIC_UUID "abcd1234"

BLECharacteristic *pCharacteristic;
bool phoneConnected = false;

// ===== LD2450 FRAME =====
#define FRAME_SIZE 30
uint8_t frame[FRAME_SIZE];
int frameIndex = 0;

// ===== DETECTION DATA =====
bool humanDetected = false;
float closestDistance = 0.0;
unsigned long lastBleSend = 0;

// =====================================================
// BLE CALLBACK
// =====================================================
class MyServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) {
    phoneConnected = true;
    Serial.println("Phone connected by BLE");
  }

  void onDisconnect(BLEServer* pServer) {
    phoneConnected = false;
    Serial.println("Phone disconnected");
    BLEDevice::startAdvertising();
  }
};

// =====================================================
// DECODE LD2450 VALUE
// =====================================================
int16_t decodeLD2450(uint8_t lowByte, uint8_t highByte) {
  uint16_t raw = lowByte | (highByte << 8);
  int16_t value = raw & 0x7FFF;

  if (raw & 0x8000) {
    return value;
  } else {
    return -value;
  }
}

// =====================================================
// SETUP
// =====================================================
void setup() {
  Serial.begin(115200);
  delay(3000);

  Serial.println("================================");
  Serial.println("ESP32-S3 + LD2450 + BLE STARTED");
  Serial.println("================================");

  // Start LD2450 UART
  ld2450.begin(256000, SERIAL_8N1, LD2450_RX, LD2450_TX);
  Serial.println("LD2450 UART started");

  // Start BLE
  BLEDevice::init(BLE_NAME);

  BLEServer *pServer = BLEDevice::createServer();
  pServer->setCallbacks(new MyServerCallbacks());

  BLEService *pService = pServer->createService(SERVICE_UUID);

  pCharacteristic = pService->createCharacteristic(
    CHARACTERISTIC_UUID,
    BLECharacteristic::PROPERTY_READ |
    BLECharacteristic::PROPERTY_NOTIFY
  );

  pCharacteristic->addDescriptor(new BLE2902());
  pCharacteristic->setValue("HUMAN:0 DIST:0.00");

  pService->start();

  BLEAdvertising *pAdvertising = BLEDevice::getAdvertising();
  pAdvertising->addServiceUUID(SERVICE_UUID);
  pAdvertising->setScanResponse(true);
  pAdvertising->start();

  Serial.println("BLE started");
  Serial.println("Device name: ESP32_LD2450");
  Serial.println("Waiting for LD2450 data...");
}

// =====================================================
// LOOP
// =====================================================
void loop() {
  readLD2450();
  sendBLE();
}

// =====================================================
// READ LD2450 DATA
// =====================================================
void readLD2450() {
  while (ld2450.available()) {
    uint8_t b = ld2450.read();

    if (frameIndex == 0) {
      if (b == 0xAA) {
        frame[frameIndex++] = b;
      }
      continue;
    }

    if (frameIndex == 1) {
      if (b == 0xFF) {
        frame[frameIndex++] = b;
      } else {
        frameIndex = 0;
      }
      continue;
    }

    frame[frameIndex++] = b;

    if (frameIndex == FRAME_SIZE) {
      frameIndex = 0;

      if (frame[0] == 0xAA &&
          frame[1] == 0xFF &&
          frame[2] == 0x03 &&
          frame[3] == 0x00 &&
          frame[28] == 0x55 &&
          frame[29] == 0xCC) {

        parseLD2450();
      }
    }
  }
}

// =====================================================
// PARSE LD2450 TARGETS
// =====================================================
void parseLD2450() {
  humanDetected = false;
  closestDistance = 999.0;

  Serial.println();
  Serial.println("========== LD2450 DATA ==========");

  for (int target = 0; target < 3; target++) {
    int base = 4 + (target * 8);

    int16_t x_mm = decodeLD2450(frame[base], frame[base + 1]);
    int16_t y_mm = decodeLD2450(frame[base + 2], frame[base + 3]);
    int16_t speed = decodeLD2450(frame[base + 4], frame[base + 5]);

    if (x_mm == 0 && y_mm == 0) {
      continue;
    }

    float x_m = x_mm / 1000.0;
    float y_m = y_mm / 1000.0;
    float distance = sqrt((x_m * x_m) + (y_m * y_m));

    if (distance > 0.2 && distance < 6.0) {
      humanDetected = true;

      if (distance < closestDistance) {
        closestDistance = distance;
      }
    }

    Serial.print("Target ");
    Serial.print(target + 1);
    Serial.print(" | X: ");
    Serial.print(x_mm);
    Serial.print(" mm | Y: ");
    Serial.print(y_mm);
    Serial.print(" mm | Distance: ");
    Serial.print(distance, 2);
    Serial.print(" m | Speed: ");
    Serial.println(speed);
  }

  if (!humanDetected) {
    closestDistance = 0.0;
  }

  Serial.print("FINAL DATA -> HUMAN:");
  Serial.print(humanDetected ? 1 : 0);
  Serial.print(" DIST:");
  Serial.print(closestDistance, 2);
  Serial.println(" m");
}

// =====================================================
// SEND DATA TO PHONE BY BLE
// =====================================================
void sendBLE() {
  if (!phoneConnected) return;

  if (millis() - lastBleSend >= 500) {
    lastBleSend = millis();

    String data = "HUMAN:";
    data += humanDetected ? "1" : "0";
    data += " DIST:";
    data += String(closestDistance, 2);

    pCharacteristic->setValue(data.c_str());
    pCharacteristic->notify();

    Serial.print("BLE SENT -> ");
    Serial.println(data);
  }
}
