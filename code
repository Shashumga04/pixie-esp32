#include <WiFi.h>
#include <PubSubClient.h>
#include <Wire.h>
#include <Adafruit_SHT4x.h>
#include <BLEDevice.h>
#include <BLEServer.h>
#include <BLEUtils.h>
#include <BLE2902.h>

// WIFI
const char* ssid = "rohaniwilson";
const char* password = "salimfaiz1234";

// MQTT
const char* mqtt_server = "broker.hivemq.com";
const int mqtt_port = 1883;
const char* mqtt_topic = "esp32s3/robot";

WiFiClient espClient;
PubSubClient client(espClient);

// BLE
BLECharacteristic *sensorCharacteristic;
bool bleConnected = false;

#define SERVICE_UUID        "12345678"
#define CHARACTERISTIC_UUID "abcd1234"

class MyServerCallbacks : public BLEServerCallbacks {
  void onConnect(BLEServer* pServer) {
    bleConnected = true;
    Serial.println("BLE connected");
  }

  void onDisconnect(BLEServer* pServer) {
    bleConnected = false;
    Serial.println("BLE disconnected");
    BLEDevice::startAdvertising();
  }
};

// SHT40
#define SDA_PIN 8
#define SCL_PIN 9
Adafruit_SHT4x sht4;
bool shtFound = false;

// HC-SR04P
#define TRIG_PIN 4
#define ECHO_PIN 5

// LD2450
#define LD2450_RX 16
#define LD2450_TX 17
HardwareSerial LD2450(1);

// MOTOR PINS
#define LEFT_IN1   10
#define LEFT_IN2   11
#define RIGHT_IN1  12
#define RIGHT_IN2  13

#define PWM_FREQ 20000
#define PWM_RES 8

// PID
float targetDistance = 80.0;
float Kp = 3.0;
float Ki = 0.02;
float Kd = 1.2;

float error = 0;
float previousError = 0;
float integral = 0;

int minSpeed = 60;
int maxSpeed = 180;

unsigned long lastControlTime = 0;
unsigned long lastSend = 0;

const unsigned long controlInterval = 100;
const unsigned long sendInterval = 5000;

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("ESP32-S3 Robot Full System Started");

  Wire.begin(SDA_PIN, SCL_PIN);

  if (sht4.begin()) {
    shtFound = true;
    sht4.setPrecision(SHT4X_HIGH_PRECISION);
    sht4.setHeater(SHT4X_NO_HEATER);
    Serial.println("SHT40 found");
  } else {
    Serial.println("SHT40 not found");
  }

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  LD2450.begin(256000, SERIAL_8N1, LD2450_RX, LD2450_TX);
  Serial.println("LD2450 UART started");

  setupMotors();
  stopMotors();

  setupWiFi();
  client.setServer(mqtt_server, mqtt_port);

  setupBLE();

  Serial.println("System ready");
}

void loop() {
  if (!client.connected()) {
    reconnectMQTT();
  }

  client.loop();

  if (millis() - lastControlTime >= controlInterval) {
    lastControlTime = millis();
    robotControl();
  }

  if (millis() - lastSend >= sendInterval) {
    lastSend = millis();

    String payload = makePayload();

    Serial.println(payload);
    client.publish(mqtt_topic, payload.c_str());

    if (bleConnected) {
      sensorCharacteristic->setValue(payload.c_str());
      sensorCharacteristic->notify();
    }
  }
}

// ================= ROBOT CONTROL =================
void robotControl() {
  float distanceCM = readUltrasonic();

  if (distanceCM <= 0) {
    stopMotors();
    Serial.println("No object detected");
    return;
  }

  if (distanceCM < 25) {
    stopMotors();
    integral = 0;
    Serial.println("Emergency stop: too close");
    return;
  }

  error = distanceCM - targetDistance;
  integral += error;
  integral = constrain(integral, -500, 500);

  float derivative = error - previousError;
  float pidOutput = (Kp * error) + (Ki * integral) + (Kd * derivative);

  previousError = error;

  int speedValue = constrain(abs(pidOutput), minSpeed, maxSpeed);

  Serial.print("Distance: ");
  Serial.print(distanceCM);
  Serial.print(" cm | PID: ");
  Serial.print(pidOutput);
  Serial.print(" | Speed: ");
  Serial.println(speedValue);

  if (error > 5) {
    moveForward(speedValue);
  } else if (error < -5) {
    moveBackward(speedValue);
  } else {
    stopMotors();
  }
}

// ================= SENSOR PAYLOAD =================
String makePayload() {
  float temperature = 0;
  float humidity = 0;
  float ultrasonic = readUltrasonic();
  String ldRaw = readLD2450RawShort();

  if (shtFound) {
    sensors_event_t humEvent;
    sensors_event_t tempEvent;
    sht4.getEvent(&humEvent, &tempEvent);

    temperature = tempEvent.temperature;
    humidity = humEvent.relative_humidity;
  }

  String payload = "{";
  payload += "\"temperature\":";
  payload += temperature;
  payload += ",\"humidity\":";
  payload += humidity;
  payload += ",\"ultrasonic_cm\":";
  payload += ultrasonic;
  payload += ",\"target_distance\":";
  payload += targetDistance;
  payload += ",\"ld2450_raw\":\"";
  payload += ldRaw;
  payload += "\"}";

  return payload;
}

// ================= HC-SR04P =================
float readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);

  if (duration == 0) {
    return -1;
  }

  return duration * 0.0343 / 2;
}

// ================= LD2450 RAW =================
String readLD2450RawShort() {
  String rawData = "";
  int count = 0;

  while (LD2450.available() && count < 40) {
    byte b = LD2450.read();

    if (b < 0x10) rawData += "0";
    rawData += String(b, HEX);
    rawData += " ";

    count++;
  }

  if (rawData.length() == 0) {
    rawData = "No data";
  }

  return rawData;
}

// ================= MOTOR SETUP =================
void setupMotors() {
  ledcAttach(LEFT_IN1, PWM_FREQ, PWM_RES);
  ledcAttach(LEFT_IN2, PWM_FREQ, PWM_RES);
  ledcAttach(RIGHT_IN1, PWM_FREQ, PWM_RES);
  ledcAttach(RIGHT_IN2, PWM_FREQ, PWM_RES);
}

// ================= MOTOR FUNCTIONS =================
void moveForward(int speedValue) {
  ledcWrite(LEFT_IN1, speedValue);
  ledcWrite(LEFT_IN2, 0);

  ledcWrite(RIGHT_IN1, speedValue);
  ledcWrite(RIGHT_IN2, 0);
}

void moveBackward(int speedValue) {
  ledcWrite(LEFT_IN1, 0);
  ledcWrite(LEFT_IN2, speedValue);

  ledcWrite(RIGHT_IN1, 0);
  ledcWrite(RIGHT_IN2, speedValue);
}

void stopMotors() {
  ledcWrite(LEFT_IN1, 0);
  ledcWrite(LEFT_IN2, 0);

  ledcWrite(RIGHT_IN1, 0);
  ledcWrite(RIGHT_IN2, 0);
}

// ================= WIFI =================
void setupWiFi() {
  Serial.print("Connecting to WiFi");

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi connected");
  Serial.print("IP address: ");
  Serial.println(WiFi.localIP());
}

// ================= MQTT =================
void reconnectMQTT() {
  while (!client.connected()) {
    Serial.print("Connecting to MQTT...");

    String clientId = "ESP32S3_Robot_";
    clientId += String(random(0xffff), HEX);

    if (client.connect(clientId.c_str())) {
      Serial.println("connected");
    } else {
      Serial.print("failed, rc=");
      Serial.println(client.state());
      delay(2000);
    }
  }
}

// ================= BLE =================
void setupBLE() {
  BLEDevice::init("ESP32S3_Robot");

  BLEServer *server = BLEDevice::createServer();
  server->setCallbacks(new MyServerCallbacks());

  BLEService *service = server->createService(SERVICE_UUID);

  sensorCharacteristic = service->createCharacteristic(
    CHARACTERISTIC_UUID,
    BLECharacteristic::PROPERTY_READ |
    BLECharacteristic::PROPERTY_NOTIFY
  );

  sensorCharacteristic->addDescriptor(new BLE2902());
  sensorCharacteristic->setValue("Waiting for robot data...");

  service->start();

  BLEAdvertising *advertising = BLEDevice::getAdvertising();
  advertising->addServiceUUID(SERVICE_UUID);
  advertising->start();

  Serial.println("BLE started. Search for ESP32S3_Robot");
}
