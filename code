// SHT40
#define SDA_PIN 8
#define SCL_PIN 9
Adafruit_SHT4x sht4;
bool shtFound = false;

// HC-SR04P
#define TRIG_PIN 4
#define ECHO_PIN 5

// LD2450
#define LD2450_RX 16
#define LD2450_TX 17
HardwareSerial LD2450(1);

// MOTOR PINS
#define LEFT_IN1   10
#define LEFT_IN2   11
#define RIGHT_IN1  12
#define RIGHT_IN2  13

#define PWM_FREQ 20000
#define PWM_RES 8

// PID
float targetDistance = 80.0;
float Kp = 3.0;
float Ki = 0.02;
float Kd = 1.2;

float error = 0;
float previousError = 0;
float integral = 0;

int minSpeed = 60;
int maxSpeed = 180;

unsigned long lastControlTime = 0;
unsigned long lastSend = 0;

const unsigned long controlInterval = 100;
const unsigned long sendInterval = 16000; // Bumped to 16s to comfortably clear ThingSpeak's 15s limit

// ================= FUNCTION PROTOTYPES =================
void setupMotors();
void stopMotors();
void moveForward(int speedValue);
void moveBackward(int speedValue);
void setupWiFi();
void setupBLE();
void robotControl();
float readUltrasonic();
String readLD2450RawShort();

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println("ESP32-S3 Robot Full System Started");

  Wire.begin(SDA_PIN, SCL_PIN);

  if (sht4.begin()) {
    shtFound = true;
    sht4.setPrecision(SHT4X_HIGH_PRECISION);
    sht4.setHeater(SHT4X_NO_HEATER);
    Serial.println("SHT40 found");
  } else {
    Serial.println("SHT40 not found");
  }

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  LD2450.begin(256000, SERIAL_8N1, LD2450_RX, LD2450_TX);
  Serial.println("LD2450 UART started");

  setupMotors();
  stopMotors();

  // Runs the advanced Wi-Fi configuration with deep flash resetting
  setupWiFi();
  
  // Initialize ThingSpeak API engine using the network client wrapper
  ThingSpeak.begin(client);

  setupBLE();

  Serial.println("System ready");
}

// ================= MAIN LOOP =================
void loop() {
  // 1. FAST LOOP: High-speed PID tracking and motor controls (Every 100ms)
  if (millis() - lastControlTime >= controlInterval) {
    lastControlTime = millis();
    robotControl();
  }

  // 2. SLOW LOOP: Non-blocking cloud updates (Every 16 seconds)
  if (millis() - lastSend >= sendInterval) {
    lastSend = millis();

    // Background Auto-Reconnect check: Avoids hanging the code if WiFi dropped
    if (WiFi.status() != WL_CONNECTED) {
      Serial.println("\n[WARNING]: WiFi connection lost! Initiating background reconnection...");
      WiFi.begin(ssid, password); 
    }

    // Gather local sensor measurements
    float temperature = 0;
    float humidity = 0;
    float ultrasonic = readUltrasonic();

    if (shtFound) {
      sensors_event_t humEvent;
      sensors_event_t tempEvent;
      sht4.getEvent(&humEvent, &tempEvent);
      temperature = tempEvent.temperature;
      humidity = humEvent.relative_humidity;
    }

    // Print diagnostics to local serial monitor
    Serial.println("\n--- Sending Multi-Field Stream to ThingSpeak ---");
    Serial.print("Temp: "); Serial.print(temperature);
    Serial.print(" | Hum: "); Serial.print(humidity);
    Serial.print(" | Dist: "); Serial.println(ultrasonic);

    // Stage field values inside the ThingSpeak buffer memory
    ThingSpeak.setField(1, temperature);
    ThingSpeak.setField(2, humidity);
    ThingSpeak.setField(3, ultrasonic);

    // Push the staged fields to the cloud if the network is healthy
    if (WiFi.status() == WL_CONNECTED) {
      int responseCode = ThingSpeak.writeFields(myChannelNumber, myWriteAPIKey);
      
      if (responseCode == 200) {
        Serial.println("ThingSpeak Upload Successful! (HTTP 200)");
      } else {
        Serial.print("ThingSpeak Upload Failed! HTTP/Error Code: ");
        Serial.println(responseCode);
        // Useful debugging codes: 
        // -301 to -304 means throttled/rate-limited (sending too fast)
      }
    } else {
      Serial.println("ThingSpeak Skipped: Network connection is down.");
    }

    // Simultaneously echo the data layout to any connected Bluetooth dashboard
    if (bleConnected) {
      String blePayload = "field1=" + String(temperature) + "&field2=" + String(humidity) + "&field3=" + String(ultrasonic);
      sensorCharacteristic->setValue(blePayload.c_str());
      sensorCharacteristic->notify();
    }
  }
}

// ================= ROBOT CONTROL =================
void robotControl() {
  float distanceCM = readUltrasonic();

  if (distanceCM <= 0) {
    stopMotors();
    Serial.println("No object detected");
    return;
  }

  if (distanceCM < 25) {
    stopMotors();
    integral = 0;
    Serial.println("Emergency stop: too close");
    return;
  }

  error = distanceCM - targetDistance;
  integral += error;
  integral = constrain(integral, -500, 500);

  float derivative = error - previousError;
  float pidOutput = (Kp * error) + (Ki * integral) + (Kd * derivative);

  previousError = error;

  int speedValue = constrain(abs(pidOutput), minSpeed, maxSpeed);

  Serial.print("Distance: ");
  Serial.print(distanceCM);
  Serial.print(" cm | PID: ");
  Serial.print(pidOutput);
  Serial.print(" | Speed: ");
  Serial.println(speedValue);

  if (error > 5) {
    moveForward(speedValue);
  } else if (error < -5) {
    moveBackward(speedValue);
  } else {
    stopMotors();
  }
}

// ================= HC-SR04P =================
float readUltrasonic() {
  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH, 30000);

  if (duration == 0) {
    return -1;
  }

  return duration * 0.0343 / 2;
}

// ================= LD2450 RAW =================
String readLD2450RawShort() {
  String rawData = "";
  int count = 0;

  while (LD2450.available() && count < 40) {
    byte b = LD2450.read();

    if (b < 0x10) rawData += "0";
    rawData += String(b, HEX);
    rawData += " ";

    count++;
  }

  if (rawData.length() == 0) {
    rawData = "No data";
  }

  return rawData;
}

// ================= MOTOR SETUP =================
void setupMotors() {
  ledcAttach(LEFT_IN1, PWM_FREQ, PWM_RES);
  ledcAttach(LEFT_IN2, PWM_FREQ, PWM_RES);
  ledcAttach(RIGHT_IN1, PWM_FREQ, PWM_RES);
  ledcAttach(RIGHT_IN2, PWM_FREQ, PWM_RES);
}

// ================= MOTOR FUNCTIONS =================
void moveForward(int speedValue) {
  ledcWrite(LEFT_IN1, speedValue);
  ledcWrite(LEFT_IN2, 0);

  ledcWrite(RIGHT_IN1, speedValue);
  ledcWrite(RIGHT_IN2, 0);
}

void moveBackward(int speedValue) {
  ledcWrite(LEFT_IN1, 0);
  ledcWrite(LEFT_IN2, speedValue);

  ledcWrite(RIGHT_IN1, 0);
  ledcWrite(RIGHT_IN2, speedValue);
}

void stopMotors() {
  ledcWrite(LEFT_IN1, 0);
  ledcWrite(LEFT_IN2, 0);

  ledcWrite(RIGHT_IN1, 0);
  ledcWrite(RIGHT_IN2, 0);
}

// ================= WIFI WITH ANTI-REFUSAL DEEP RESET =================
void setupWiFi() {
  Serial.println("Initializing Wi-Fi Radio Isolation Layer...");
  
  // 1. Force disconnect and wipe old configurations cached in flash memory
  WiFi.disconnect(true, true); 
  delay(1000); 

  // 2. Explicitly pin the hardware mode to Station Mode (Client mode)
  WiFi.mode(WIFI_STA);
  delay(500);

  Serial.print("Connecting to WiFi Network: ");
  Serial.println(ssid);
  
  // 3. Begin connection handshake
  WiFi.begin(ssid, password);

  int attempts = 0;
  // Let it attempt for a solid 15 seconds max (30 steps * 500ms)
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println();
    Serial.println("WiFi connected successfully!");
    Serial.print("IP address: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println();
    Serial.print("WiFi Handshake Terminated. Code: ");
    Serial.println(WiFi.status());
    Serial.println("Booting robot in local offline/BLE monitoring mode.");
  }
}

// ================= BLE =================
void setupBLE() {
  BLEDevice::init("ESP32S3_Robot");

  BLEServer *server = BLEDevice::createServer();
  server->setCallbacks(new MyServerCallbacks());

  BLEService *service = server->createService(SERVICE_UUID);

  sensorCharacteristic = service->createCharacteristic(
    CHARACTERISTIC_UUID,
    BLECharacteristic::PROPERTY_READ |
    BLECharacteristic::PROPERTY_NOTIFY
  );

  sensorCharacteristic->addDescriptor(new BLE2902());
  sensorCharacteristic->setValue("Waiting for field data configuration...");

  service->start();

  BLEAdvertising *advertising = BLEDevice::getAdvertising();
  advertising->addServiceUUID(SERVICE_UUID);
  advertising->start();

  Serial.println("BLE System Armed. Scan for 'ESP32S3_Robot'");
}
